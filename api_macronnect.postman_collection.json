  "item": [
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Validaciones (tests automatizados)\r",
              "pm.test(\"Status code es 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const body = pm.response.json();\r",
              "\r",
              "pm.test(\"La respuesta incluye un token\", function () {\r",
              "    pm.expect(body.token).to.be.a(\"string\").and.to.not.be.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"El tipo de token es Bearer\", function () {\r",
              "    pm.expect(body.tipo).to.eql(\"Bearer\");\r",
              "});\r",
              "\r",
              "// 2. Guardar el token en el environment para reutilizarlo automáticamente\r",
              "if (body.token) {\r",
              "    pm.environment.set(\"token\", body.token);\r",
              "    console.log(\"Token guardado en el environment 'Local'.\");\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
